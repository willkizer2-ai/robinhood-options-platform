# ─── Robinhood Options Intelligence Platform ───────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git!

# App
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key

# Database (local dev — use Docker or local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/robinhood_options
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/robinhood_options

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ─── Market Data APIs ───────────────────────────────────────────────────────
# Polygon.io — Free tier available: https://polygon.io/
POLYGON_API_KEY=

# Alpha Vantage — Free tier: https://www.alphavantage.co/
ALPHA_VANTAGE_KEY=

# Tradier — Free sandbox: https://developer.tradier.com/
TRADIER_API_KEY=

# Finnhub — Free tier: https://finnhub.io/
FINNHUB_API_KEY=

# ─── News APIs ──────────────────────────────────────────────────────────────
# NewsAPI — Free tier: https://newsapi.org/
NEWSAPI_KEY=

# ─── AI / NLP ───────────────────────────────────────────────────────────────
# OpenAI (optional — for advanced NLP)
OPENAI_API_KEY=

# ─── Alerts ─────────────────────────────────────────────────────────────────
# Slack webhook URL (optional)
ALERT_WEBHOOK_URL=

# ─── Performance ────────────────────────────────────────────────────────────
LOW_MEMORY_MODE=false
USE_REDIS=false
REDIS_URL=redis://localhost:6379
